# ---------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit a populated .env.
# ---------------------------------------------------------------------------

# --- Model / pipeline ---
MODEL_NAME=ArcFace
DETECTOR_BACKEND=retinaface
EMBEDDING_DIM=512
# Cosine DISTANCE cutoff. Match iff distance <= this. Lower = stricter.
COSINE_THRESHOLD=0.40

# --- PostgreSQL (pgvector) ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=faces
PG_USER=postgres
PG_PASSWORD=change-me

# --- Redis (rate limiting) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW_S=60

# --- AWS S3 cold storage ---
AWS_REGION=us-east-1
S3_BUCKET=payment-fraud-review-snapshots
S3_PREFIX=fraud_reviews/

# Credentials: prefer an EC2 instance role on g6.xlarge. For local dev only,
# you may set the standard AWS SDK variables instead:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
